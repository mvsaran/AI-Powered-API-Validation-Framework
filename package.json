{
  "name": "ai-api-validator",
  "version": "1.0.0",
  "description": "AI-Powered API Validation Framework using Playwright, TypeScript, and Ollama",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "clean": "npx rimraf allure-results allure-report"
  },
  "keywords": [
    "playwright",
    "ollama",
    "typescript",
    "allure",
    "api-testing",
    "ai-validation"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@playwright/test": "^1.44.0",
    "dotenv": "^16.4.5",
    "ollama": "^0.5.1",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "allure-commandline": "^2.29.0",
    "allure-playwright": "^3.0.0-beta.2",
    "rimraf": "^5.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
